# Sentinex Configuration

# Cameras (Format: RTSP_URL_<NAME>=url)
# RTSP_URL_CAM1=rtsp://user:pass@192.168.1.10:554/stream
# SYSTEM_PROMPT_CAM1="Describe this backyard camera..."

# Analysis
INTERVAL=60
FRAME_MAX_WIDTH=960
JPEG_QUALITY=70
MOTION_FILTER_ENABLED=1
MOTION_DOWNSCALE_WIDTH=320
MOTION_DIFF_THRESHOLD=24
MOTION_MIN_CHANGED_RATIO=0.002
MOTION_CROP_ENABLED=1
MOTION_CROP_PADDING=0.18
MOTION_CROP_MAX_AREA_RATIO=0.75
MOTION_SKIP_LOW_CHANGE=0
FULL_FRAME_EVERY_SECONDS=300
MOTION_SKIP_SLEEP_SECONDS=1
MOTION_MAX_SKIPS_BEFORE_ANALYSIS=10
SCORE_THRESHOLD=0.8
HUMAN_ALERT_COOLDOWN=300
HUMAN_ALERT_MIN_SCORE=0.2

# TTS Alert
TTS_ENABLED=1
TTS_MESSAGE="Alerta. Riesgo detectado en la zona."
TTS_LANG="es"
TTS_COOLDOWN=60

# Heartbeat
HEARTBEAT_ENABLED=1
HEARTBEAT_INTERVAL=86400

# Logging
LOG_LEVEL=INFO
LOG_FILE=sentinex.log

# LLM API
LM_STUDIO_API=http://localhost:1234/v1
MODEL_NAME=qwen3-vl-8b
API_KEY=
LM_TIMEOUT=60
LLM_MAX_TOKENS=220

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OmniStatus
ENABLE_OMNISTATUS=0
OMNISTATUS_ENDPOINT=http://localhost:8001/event
OMNISTATUS_DEDUP_ENABLED=1
OMNISTATUS_DEDUP_WINDOW_SECONDS=30
OMNISTATUS_DEDUP_MAX_SAMPLES=3

# Critical webhook (IFTTT, smart light, etc.)
CRITICAL_WEBHOOK_URL=
CRITICAL_CLEAR_WEBHOOK_URL=
CRITICAL_WEBHOOK_COOLDOWN=30

# Web Admin
ADMIN_REFRESH_MS=15000
